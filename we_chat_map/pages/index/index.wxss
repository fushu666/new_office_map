page {
  height: 100vh;
  background: #4f8cad;
  overflow: hidden;
}

.page {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

.map-area {
  position: fixed;
  inset: 0;
  width: 100vw;
  height: 100vh;
  background: #4f8cad;
}

.top-safe {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 3;
  pointer-events: none;
  background: linear-gradient(180deg, rgba(16, 35, 50, 0.36), rgba(16, 35, 50, 0));
}

.map-movable {
  overflow: hidden;
}

.map-image {
  display: block;
}

.vector-canvas {
  display: block;
}

.controls {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 2;
  box-sizing: border-box;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 16rpx;
  background: rgba(16, 35, 50, 0.9);
  color: #f8f1da;
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.28);
}

@media (min-width: 700px) {
  .controls {
    left: 32rpx;
    right: auto;
    bottom: calc(32rpx + env(safe-area-inset-bottom));
    width: 560rpx;
  }
}

@media (orientation: landscape) {
  .controls {
    left: 24rpx;
    right: auto;
    bottom: 24rpx;
    width: 520rpx;
    padding: 18rpx;
  }

  .head {
    margin-bottom: 14rpx;
  }

  .timeline-slider {
    margin-top: 12rpx;
  }

  .actions {
    margin-top: 10rpx;
  }
}

.head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.25;
}

.status {
  margin-top: 6rpx;
  color: rgba(248, 241, 218, 0.66);
  font-size: 23rpx;
}

.year-label {
  flex: 0 0 auto;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.15;
}

.year-row {
  display: grid;
  grid-template-columns: 1fr 128rpx;
  gap: 14rpx;
}

.year-input {
  height: 72rpx;
  box-sizing: border-box;
  padding: 0 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  font-size: 28rpx;
}

.load-button,
.actions button {
  height: 72rpx;
  margin: 0;
  border-radius: 12rpx;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 72rpx;
}

.load-button {
  background: #ff6f59;
}

.timeline-slider {
  margin-top: 18rpx;
}

.count {
  color: rgba(248, 241, 218, 0.62);
  font-size: 22rpx;
  text-align: right;
}

.actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 16rpx;
}

.actions button {
  background: rgba(255, 255, 255, 0.12);
}
